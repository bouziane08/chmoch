# --------------------------------------
# 1. اختيار صورة Node
# --------------------------------------
FROM node:20-alpine AS base

# تثبيت bash و git
RUN apk add --no-cache bash git

# ======================================
# 2. إعداد مجلد العمل
# ======================================
WORKDIR /usr/src/app

# ======================================
# 3. نسخ ملفات package
# ======================================
COPY package.json pnpm-lock.yaml ./
# تثبيت pnpm عالميًا
RUN npm install -g pnpm

# تثبيت التبعيات فقط
RUN pnpm install 

# ======================================
# 4. نسخ الكود
# ======================================
COPY . .

# ======================================
# 5. بناء المشروع للإنتاج (يمكن تغييره لـ dev)
# ======================================
RUN pnpm build

# ======================================
# 6. التعرض للمنفذ
# ======================================
EXPOSE 3000

# ======================================
# 7. تشغيل المشروع
# ======================================
CMD ["pnpm", "dev"]
